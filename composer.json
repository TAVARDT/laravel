{
  "name": "tavardt/laravel-security",
  "description": "Elite B2B Security Middleware for Laravel Applications — TAVARDT Agency",
  "version": "1.0.0",
  "type": "library",
  "keywords": ["laravel", "security", "middleware", "headers", "hsts", "csp", "tavardt"],
  "homepage": "https://ag.tavardt.com",
  "license": "MIT",
  "authors": [
    {
      "name": "TAVARDT Agency",
      "email": "contact@tavardt.com",
      "homepage": "https://ag.tavardt.com",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/http": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Tavardt\\LaravelSecurity\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Tavardt\\LaravelSecurity\\SecurityServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true
  }
}
